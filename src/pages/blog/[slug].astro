---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getPosts, postUrl, readMinutes, fullDate, isPoem, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

interface Props {
  post: Post;
  posts: Post[];
}

const { post, posts } = Astro.props;
const { Content } = await render(post);

const category = post.data.categories[0];
const poem = isPoem(post);

// "Keep reading": same primary category first, then most recent — never self.
const related = [
  ...posts.filter((p) => p.id !== post.id && category && p.data.categories.includes(category)),
  ...posts.filter((p) => p.id !== post.id && (!category || !p.data.categories.includes(category))),
].slice(0, 2);

const canonical = new URL(postUrl(post), Astro.site).href;
const heroImageUrl = post.data.heroImage && new URL(post.data.heroImage, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  ...(post.data.excerpt && { description: post.data.excerpt }),
  ...(heroImageUrl && { image: heroImageUrl }),
  datePublished: post.data.date.toISOString(),
  ...(category && { articleSection: category }),
  inLanguage: 'en',
  mainEntityOfPage: canonical,
  author: {
    '@type': 'Person',
    name: 'Michael J. Schiuma',
    url: Astro.site!.href,
  },
};
---
<Base
  title={`${post.data.title} — MJS Writes`}
  description={post.data.excerpt}
  active="blog"
  ogType="article"
  ogImage={post.data.heroImage}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <meta property="article:author" content="Michael J. Schiuma" />
    {post.data.categories.map((c) => <meta property="article:tag" content={c} />)}
  </Fragment>

  <article>
    <div class="article-header">
      <a href="/blog/" class="back">← The Journal</a>
      {category && <div class="article-cat">{post.data.categories.join(' · ')}</div>}
      <h1>{post.data.title}</h1>
      <div class="byline">
        <span class="author">Michael J. Schiuma</span>
        <span class="dot"></span>
        <span>{fullDate(post.data.date)}</span>
        <span class="dot"></span>
        <span>{readMinutes(post.body)} min read</span>
      </div>
    </div>

    {post.data.heroImage && (
      <figure class="article-hero">
        <div class="article-hero-frame"><img src={post.data.heroImage} alt={post.data.title} /></div>
        {post.data.heroCaption && (
          <figcaption class="hero-caption">
            {post.data.heroCaptionUrl
              ? <a href={post.data.heroCaptionUrl}>{post.data.heroCaption}</a>
              : post.data.heroCaption}
          </figcaption>
        )}
      </figure>
    )}

    <div class:list={['article-body', { poem }]}>
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <section class="keep-reading">
      <div class="keep-reading-inner">
        <h2>Keep reading</h2>
        <div class="keep-grid">
          {related.map((m) => (
            <a href={postUrl(m)} class="keep-card">
              <div class="keep-img"><img src={m.data.heroImage} alt={m.data.title} loading="lazy" /></div>
              <div class="keep-body">
                <div class="keep-tag">{m.data.categories[0] ?? 'Journal'}</div>
                <h3>{m.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  article { animation: floatUp 0.7s ease both; }
  .article-header {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 80px) 24px clamp(28px, 3vw, 40px);
    text-align: center;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-bottom: 26px;
  }
  .article-cat {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(38px, 5.2vw, 62px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: 22px;
  }
  .byline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-size: 14px;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }
  .author { font-weight: 600; color: var(--ink); }
  .dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); }

  .article-hero { max-width: 1080px; margin: 0 auto clamp(36px, 4vw, 56px); padding: 0 24px; }
  .article-hero-frame {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-image);
    aspect-ratio: 16 / 9;
  }
  .article-hero-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; display: block; }
  .hero-caption {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink-soft);
    margin-top: 14px;
  }
  .hero-caption a { color: var(--accent-deep); text-underline-offset: 3px; }

  .article-body {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 24px clamp(48px, 6vw, 80px);
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.78;
    color: var(--ink);
  }
  .article-body :global(p) { margin-bottom: 26px; }
  /* Section dividers between titled sections (opinion & tech pieces) */
  .article-body :global(hr) {
    border: none;
    width: 90px;
    height: 1px;
    background: var(--accent);
    opacity: 0.55;
    margin: 48px auto;
  }
  .article-body:not(.poem) :global(> p:first-of-type)::first-letter {
    float: left;
    font-size: 74px;
    line-height: 0.72;
    padding: 8px 12px 0 0;
    color: var(--accent);
    font-weight: 500;
  }
  .article-body :global(blockquote) {
    margin: 36px 0;
    padding: 6px 0 6px 28px;
    border-left: 3px solid var(--accent);
    font-style: italic;
    font-size: 25px;
    line-height: 1.4;
    color: var(--accent-deep);
  }
  .article-body :global(blockquote p) { margin-bottom: 0; }
  .article-body :global(img) { width: 100%; border-radius: 10px; box-shadow: var(--shadow-card); margin: 10px 0; }
  .article-body :global(figure) { margin: 10px 0 26px; }
  .article-body :global(figure img) { margin: 0; }
  .article-body :global(figcaption) {
    text-align: center;
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink-soft);
    margin-top: 10px;
  }
  .article-body :global(a) { color: var(--accent-deep); text-decoration-color: rgba(198, 99, 58, 0.4); text-underline-offset: 3px; }
  .article-body :global(h1), .article-body :global(h2), .article-body :global(h3), .article-body :global(h4) {
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 34px 0 16px;
  }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 26px 26px; }
  .article-body.poem :global(img) { margin: 18px 0; }

  .keep-reading { background: var(--bg-paper-deep); padding: clamp(48px, 6vw, 80px) var(--pad-x); }
  .keep-reading-inner { max-width: 1180px; margin: 0 auto; }
  .keep-reading h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 2.8vw, 34px);
    margin-bottom: 32px;
  }
  .keep-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: clamp(20px, 2.4vw, 32px); }
  .keep-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    background: var(--surface-card);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.3s ease;
  }
  .keep-card:hover { box-shadow: var(--shadow-card-hover); }
  .keep-img { aspect-ratio: 16 / 10; overflow: hidden; }
  .keep-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s ease; }
  .keep-card:hover .keep-img img { transform: scale(1.05); }
  .keep-body { padding: 24px 24px 28px; }
  .keep-tag {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 9px;
  }
  .keep-body h3 { font-family: var(--font-serif); font-style: italic; font-weight: 400; font-size: 23px; line-height: 1.14; }
</style>
