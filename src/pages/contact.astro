---
import Base from '../layouts/Base.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { SOCIALS } from '../lib/socials';

const [INSTAGRAM, ...OTHER_SOCIALS] = SOCIALS;
---
<Base title="Contact — MJS Writes" description="Get in touch — custom poems, readings, mental-health advocacy, or just to say hello." active="contact" ctaLabel="Say hello" ctaHref="#form">

  <section id="form" class="contact-hero">
    <div class="caveat contact-hey">say hello</div>
    <h1>Let's talk.</h1>
    <p class="contact-lede">Whether you'd like a custom poem, want to talk mental health, book a reading, or just share what a piece meant to you — the best way to reach me is on social. My DMs are open, and Instagram is where I'm quickest to reply.</p>

    <a href="https://ig.me/m/poetrybymjs" target="_blank" rel="noopener" class="ig-chip">
      <SocialIcon social={INSTAGRAM} size={22} />
      <span>Message @poetrybymjs</span>
      <span class="ig-chip-note">DMs open →</span>
    </a>

    <div class="social-grid">
      {OTHER_SOCIALS.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" class="social-chip">
          <SocialIcon social={s} size={20} />{s.name}
        </a>
      ))}
    </div>

    <div class="reach-row">
      <div>
        <div class="detail-label">Email</div>
        <a href="mailto:michaelschiuma@gmail.com" class="detail-link">michaelschiuma@gmail.com</a>
      </div>
      <div>
        <div class="detail-label">Phone</div>
        <a href="tel:+19736474153" class="detail-link">973-647-4153</a>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-inner">
      <div class="about-photo">
        <img src="/assets/author-portrait.jpg" alt="Michael reading by the New York City skyline at sunset" />
        <div class="about-chip"><div class="caveat about-chip-text">from new york, with love</div></div>
      </div>
      <div>
        <div class="caveat about-hey">a little about me</div>
        <h2>Hi, I'm <span class="about-em">Michael</span></h2>
        <div class="bio">
          <p>I'm an author, poet, public speaker, and mental-health advocate from Sparta, NJ. My writing covers a multitude of topics — from technology and politics to travel and poetry, and the messy truth of living with mental illness.</p>
          <p>Following a devastating episode of psychosis induced by bipolar disorder, I was inspired to write <em>(In)Sane</em> — to help others better understand mental illness and add to the conversation around it. I also keep a blog, <em>The Manic Millennial</em>, dedicated to broadening mental-health awareness.</p>
          <p>And I love writing poetry, as my recent releases show: <em>from new york, with love</em> (2023), <em>words to love by</em> (2024), and my latest collection, <em>to be loved by a poet</em> (2024). From eloquent stanzas that tug at the heartstrings to lighthearted, relatable pieces, I hope my poetry leaves romantics joyful and inspired.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="skyline">
    <img src="/assets/author-skyline.jpg" alt="Michael reading on a park bench with the New York City skyline at sunset" />
    <div class="skyline-caption">
      <div class="caveat skyline-hey">where the words come from</div>
      <div class="skyline-sub">a quiet bench, a skyline, and a good book</div>
    </div>
  </div>
</Base>

<style>
  .contact-hero {
    background: var(--bg-paper-deep);
    text-align: center;
    padding: clamp(56px, 8vw, 104px) clamp(24px, 5vw, 72px) clamp(56px, 7vw, 88px);
    animation: floatUp 0.8s ease both;
  }
  .contact-hey { font-size: 30px; margin-bottom: 10px; display: inline-block; transform: rotate(-2deg); }
  .contact-hero h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .contact-lede { font-size: 18px; line-height: 1.7; color: #5a4f47; max-width: 54ch; margin: 0 auto 40px; }

  .ig-chip {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--accent);
    color: var(--bg-paper);
    text-decoration: none;
    font-size: 17px;
    font-weight: 600;
    padding: 16px 30px;
    border-radius: 100px;
    box-shadow: var(--shadow-cta);
    margin-bottom: 34px;
    transition: background 0.25s ease;
  }
  .ig-chip:hover { background: var(--accent-deep); }
  .ig-chip-note {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(246, 238, 227, 0.18);
    padding: 5px 12px;
    border-radius: 100px;
  }

  .social-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; max-width: 760px; margin: 0 auto 48px; }
  .social-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-paper);
    border: 1px solid rgba(44, 35, 32, 0.1);
    border-radius: 100px;
    padding: 12px 22px;
    text-decoration: none;
    color: var(--ink);
    font-size: 15px;
    font-weight: 600;
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .social-chip:hover { border-color: var(--accent); color: var(--accent); }

  .reach-row {
    display: flex;
    justify-content: center;
    gap: clamp(36px, 6vw, 80px);
    flex-wrap: wrap;
    border-top: 1px solid rgba(44, 35, 32, 0.1);
    padding-top: 36px;
    max-width: 640px;
    margin: 0 auto;
  }
  .detail-label {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 5px;
  }
  .detail-link {
    font-family: var(--font-serif);
    font-size: 21px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
  }

  .about { padding: clamp(56px, 8vw, 100px) var(--pad-x); }
  .about-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }
  .about-photo { position: relative; }
  .about-photo img { width: 100%; border-radius: 14px; box-shadow: 0 26px 60px rgba(44, 35, 32, 0.26); display: block; }
  .about-chip {
    position: absolute;
    bottom: -16px;
    left: -16px;
    background: var(--surface-cream);
    border-radius: 12px;
    padding: 11px 18px;
    box-shadow: 0 10px 30px rgba(44, 35, 32, 0.2);
  }
  .about-chip-text { font-size: 20px; line-height: 1.1; }
  .about-hey { font-size: 28px; margin-bottom: 2px; }
  .about h2 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(32px, 4vw, 52px);
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .about-em { font-style: italic; color: var(--accent-deep); }
  .bio { font-family: var(--font-serif); font-size: 18px; line-height: 1.75; color: var(--ink); }
  .bio p { margin-bottom: 20px; }
  .bio p:last-child { margin-bottom: 0; }

  .skyline { position: relative; }
  .skyline > img {
    width: 100%;
    height: clamp(300px, 44vw, 560px);
    object-fit: cover;
    object-position: center 38%;
    display: block;
  }
  .skyline-caption {
    position: absolute;
    bottom: clamp(20px, 4vw, 44px);
    left: clamp(24px, 5vw, 72px);
    color: var(--bg-paper);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }
  .skyline-hey { font-size: clamp(24px, 3vw, 34px); margin-bottom: 2px; color: var(--bg-paper); }
  .skyline-sub { font-family: var(--font-serif); font-style: italic; font-size: clamp(16px, 1.8vw, 20px); opacity: 0.95; }

  @media (max-width: 860px) {
    .about-inner { grid-template-columns: 1fr; }
  }
</style>

