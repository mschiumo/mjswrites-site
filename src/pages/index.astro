---
import Base from '../layouts/Base.astro';
import Lightbox from '../components/Lightbox.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { getPosts, postUrl, readMinutes, monthYear } from '../lib/posts';
import { SOCIALS, ETSY_LISTING } from '../lib/socials';

const posts = (await getPosts()).slice(0, 8);

const SITE = Astro.site!.href;
const author = {
  '@type': 'Person',
  '@id': `${SITE}#author`,
  name: 'Michael J. Schiuma',
  url: SITE,
  jobTitle: 'Author & Poet',
  description:
    'Author of the bipolar memoir (In)Sane: Memoirs of a Manic Millennial and three poetry collections; writes on mental health, love, and recovery.',
  image: new URL('/assets/author-portrait.jpg', SITE).href,
  sameAs: SOCIALS.map((s) => s.url),
  knowsAbout: [
    'bipolar disorder',
    'mental health',
    'depression',
    'anxiety',
    'mania',
    'recovery',
    'memoir writing',
    'poetry',
  ],
};

const book = (name: string, image: string, url: string, description: string, genre: string, keywords: string) => ({
  '@context': 'https://schema.org',
  '@type': 'Book',
  name,
  author: { '@id': `${SITE}#author` },
  image: new URL(image, SITE).href,
  url,
  description,
  genre,
  keywords,
  inLanguage: 'en',
});

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'MJS Writes',
    url: SITE,
    description:
      'Author site of Michael J. Schiuma — bipolar memoir, poetry collections, custom typewriter poems, and a journal on mental health.',
    keywords:
      'bipolar disorder, bipolar memoir, mental health, mental health awareness, depression, anxiety, mania, recovery, memoir, poetry',
    author: { '@id': `${SITE}#author` },
  },
  { '@context': 'https://schema.org', ...author },
  book(
    '(In)Sane: Memoirs of a Manic Millennial',
    '/assets/insane.jpg',
    'https://a.co/d/aE0W78i',
    'A raw two-part memoir of undiagnosed bipolar disorder, a psych-ward low, and the climb back to hope.',
    'Memoir',
    'bipolar memoir, bipolar disorder, mental health, mania, manic episode, depression, psych ward, recovery, mental illness',
  ),
  book(
    'words to love by',
    '/assets/words.jpg',
    'https://a.co/d/a3ZDwUv',
    'A poetry collection on love, loss, and being human.',
    'Poetry',
    'love poetry, heartbreak poems, poetry collection, poems about love, mental health',
  ),
  book(
    'to be loved by a poet',
    '/assets/poet.jpg',
    'https://www.amazon.com/be-loved-poet-Michael-Schiuma/dp/B0DJ7CT6CG',
    'Poems on what it means to love — and to be loved by — a poet.',
    'Poetry',
    'love poetry, romantic poems, poetry collection, poems about love',
  ),
  book(
    'from new york, with love',
    '/assets/newyork_scene.jpg',
    'https://a.co/d/9Sp1AEu',
    'A love letter to New York in poems.',
    'Poetry',
    'New York poetry, city poems, love poetry, poetry collection',
  ),
];

const POEM_PHOTOS = [
  { img: '/assets/tw-tobeloved.jpg', alt: 'a typed poem — to be loved by a poet' },
  { img: '/assets/tw-fragment.jpg', alt: 'a typed poem resting among roses' },
  { img: '/assets/tw-tryasthey.jpg', alt: 'a typed poem — try as they may' },
  { img: '/assets/tw-machine.jpg', alt: 'a vintage Smith-Corona typewriter with roses' },
];
---
<Base
  title="MJS Writes — Bipolar Memoir & Poetry by Michael J. Schiuma"
  description="Author Michael J. Schiuma writes memoir and poetry on bipolar disorder and mental health. Read (In)Sane: Memoirs of a Manic Millennial and his poetry collections."
  active="home"
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <header id="top" class="hero">
    <div class="hero-copy">
      <div class="caveat hero-hey">hey there,</div>
      <h1 id="hero-title">I'm Michael —<br /><span class="hero-em">a writer</span> at heart.</h1>
      <p>Poet, memoirist, and mental-health advocate. I write to make sense of the madness — and to help you find the words when your own feel far away.</p>
      <div class="hero-ctas">
        <a href="#memoir" class="btn btn--ink">Read my story</a>
        <a href="#poetry" class="link-underline">Explore the poetry →</a>
      </div>
    </div>
    <div class="hero-media">
      <img src="/assets/poet.jpg" alt="to be loved by a poet, resting among autumn leaves" />
      <div class="hero-fade"></div>
      <div class="hero-chip">
        <div class="hero-chip-title">"to be loved by a poet"</div>
        <div class="hero-chip-sub">latest poetry collection</div>
      </div>
    </div>
  </header>

  <!-- theme strip -->
  <div class="theme-strip">
    <span>mental health</span><i>✦</i>
    <span>bipolar &amp; recovery</span><i>✦</i>
    <span>poetry &amp; love</span><i>✦</i>
    <span>travel</span><i>✦</i>
    <span>technology</span><i>✦</i>
    <span>politics</span>
  </div>

  <!-- MEMOIR -->
  <section id="memoir" class="memoir" data-reveal-group>
    <div class="memoir-cover reveal">
      <img src="/assets/insane.jpg" alt="(In)Sane memoir cover among candlelight and berries" />
      <div class="memoir-badge">Out now</div>
    </div>
    <div class="reveal">
      <div class="eyebrow memoir-eyebrow">The Memoir</div>
      <h2 class="memoir-title">(In)Sane</h2>
      <div class="memoir-sub">Memoirs of a Manic Millennial</div>
      <p class="memoir-p">(In)Sane is an expedition through the depths of a mind lost in mania. After years of suffering through undiagnosed Bipolar, I found myself at the precipice of disaster — jobless, broke, and alone in a psych ward. This harrowing account of my sojourn through the mental-healthcare system touches on the moments of desperation and triumph alike.</p>
      <p class="memoir-p memoir-p--last">Told in two parts that strive to capture the full spectrum of moods that comprise Bipolar, <em>(In)Sane</em> brings understanding through brutally honest accounts of what it's truly like to grapple with uncontrolled mental illness — and what it means to find hope and purpose on the other side.</p>
      <div class="memoir-ctas">
        <a href="https://a.co/d/aE0W78i" target="_blank" rel="noopener" class="btn btn--accent">Buy on Amazon →</a>
        <span class="memoir-aside">a story about finding purpose on the other side</span>
      </div>
    </div>
  </section>

  <!-- POETRY -->
  <section id="poetry" class="poetry">
    <div class="poetry-head reveal">
      <div class="eyebrow eyebrow--on-dark">My Poetic Side</div>
      <h2>Words to <span class="poetry-em">love</span> by</h2>
      <p>Three collections, written from the heart — for whenever you're in love, heartbroken, struggling, or striving.</p>
    </div>
    <div class="poetry-grid" data-reveal-group>
      <div class="book-card reveal">
        <div class="book-cover"><img src="/assets/words.jpg" alt="words to love by cover" /></div>
        <div class="book-body">
          <h3>words to love by</h3>
          <p>A compilation dating back to 2017 — my best effort at expressing what love truly means, and the color it adds to our lives.</p>
          <a href="https://a.co/d/a3ZDwUv" target="_blank" rel="noopener">Read it →</a>
        </div>
      </div>
      <div class="book-card book-card--featured reveal">
        <div class="book-cover">
          <img src="/assets/poet.jpg" alt="to be loved by a poet cover" />
          <div class="book-badge">Newest</div>
        </div>
        <div class="book-body">
          <h3>to be loved by a poet</h3>
          <p>Custom poetry written for followers, friends, and family — a window into the romance, hardship, and triumphs of others. There's something here for <strong>you.</strong></p>
          <a href="https://www.amazon.com/be-loved-poet-Michael-Schiuma/dp/B0DJ7CT6CG" target="_blank" rel="noopener">Read it →</a>
        </div>
      </div>
      <div class="book-card reveal">
        <div class="book-cover"><img src="/assets/newyork_scene.jpg" alt="from new york, with love — resting among autumn leaves" /></div>
        <div class="book-body">
          <h3>from new york, with love</h3>
          <p>A love story told through poetry — the ache of longing for someone, and the quiet hope of awaiting their return.</p>
          <a href="https://a.co/d/9Sp1AEu" target="_blank" rel="noopener">Read it →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CUSTOM POETRY FEATURE -->
  <section class="custom">
    <div class="custom-head reveal">
      <div class="eyebrow">Featured — From the Shop</div>
      <h2>A poem, <span class="custom-em">typed just for you</span></h2>
    </div>
    <div class="custom-grid" data-reveal-group>
      <div class="custom-photo reveal">
        <img src="/assets/tw-picture.jpg" alt="An original poem typed on a vintage teal typewriter" />
        <div class="custom-tag">typed on a real typewriter</div>
      </div>
      <div class="reveal">
        <h3 class="custom-title">Personalized Custom Poetry</h3>
        <p class="custom-p">Tell me about a person, a moment, a heartbreak, or a celebration — and I'll write you an original poem, typed on a vintage typewriter and sent to your door. No two are ever alike. Perfect for weddings, anniversaries, memorials, or simply saying what you can't quite put into words.</p>
        <div class="custom-bullets">
          <div><i>✦</i> Written from scratch, just for your story</div>
          <div><i>✦</i> Typed on a working vintage typewriter</div>
          <div><i>✦</i> A keepsake made to be framed &amp; kept</div>
        </div>
        <div class="custom-ctas">
          <a href={ETSY_LISTING} target="_blank" rel="noopener" class="btn btn--accent">Order on Etsy →</a>
          <a href="/shop/" class="link-underline">Visit the shop</a>
        </div>
      </div>
    </div>
    <div class="gallery reveal">
      <div class="gallery-head">
        <h3>A few pieces I've typed</h3>
        <a href={ETSY_LISTING} target="_blank" rel="noopener">See more on Etsy →</a>
      </div>
      <div class="gallery-grid">
        {POEM_PHOTOS.map((p) => (
          <button type="button" class="gallery-item" data-lightbox-src={p.img} data-lightbox-alt={p.alt} aria-label={`View larger: ${p.alt}`}>
            <img src={p.img} alt={p.alt} />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- TRAILER -->
  <section class="trailer" data-reveal-group>
    <div class="eyebrow reveal">Watch</div>
    <h2 class="reveal">The official <span class="trailer-em">trailer</span></h2>
    <div class="trailer-frame reveal">
      <iframe
        src="https://www.youtube.com/embed/iio3IAiuVPg?rel=0&showinfo=0"
        title="to be loved by a poet — trailer"
        allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
        allowfullscreen></iframe>
    </div>
  </section>

  <!-- BLOG CAROUSEL -->
  <section class="latest reveal">
    <div class="latest-inner">
      <div class="latest-head">
        <h2>The latest from my <span class="latest-em">blog</span></h2>
        <div class="latest-controls">
          <a href="/blog/">View all →</a>
          <div class="latest-arrows">
            <button data-scroll="-1" aria-label="Previous posts">←</button>
            <button data-scroll="1" aria-label="Next posts">→</button>
          </div>
        </div>
      </div>
      <div data-carousel class="latest-track">
        {posts.map((post, i) => (
          <a href={postUrl(post)} class="post-card">
            <div class="post-card-img">
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
              {i === 0 && <span class="post-card-latest">Latest</span>}
            </div>
            <div class="post-card-body">
              <div class="post-card-tag">{post.data.categories[0] ?? 'Journal'}</div>
              <h3>{post.data.title}</h3>
              <div class="post-card-meta">{monthYear(post.data.date)} · {readMinutes(post.body)} min read</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOLLOW -->
  <section class="follow reveal">
    <div class="follow-head">
      <div class="caveat follow-hey">let's keep in touch</div>
      <h2>Follow along</h2>
    </div>
    <div class="follow-chips">
      {SOCIALS.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" class="follow-chip">
          <SocialIcon social={s} />{s.name}
        </a>
      ))}
    </div>
  </section>

  <Lightbox />
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: stretch;
    min-height: min(88vh, 760px);
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 72px var(--pad-x);
    animation: floatUp 0.9s ease both;
  }
  .hero-hey {
    font-size: 30px;
    line-height: 1;
    margin-bottom: 14px;
    transform: rotate(-2deg);
    transform-origin: left;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(46px, 6vw, 82px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin-bottom: 26px;
  }
  .hero-em { font-style: italic; color: var(--accent-deep); }
  .type-caret {
    display: inline-block;
    width: 3px;
    height: 0.82em;
    background: var(--accent-deep);
    margin-left: 5px;
    vertical-align: -0.06em;
    animation: caretBlink 1s steps(1) infinite;
  }
  .type-caret--done { animation: none; opacity: 0; transition: opacity 0.5s ease; }
  .hero-copy p { font-size: 19px; line-height: 1.65; color: var(--ink-soft); max-width: 34ch; margin-bottom: 36px; }
  .hero-ctas { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .hero-media { position: relative; overflow: hidden; }
  .hero-media > img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .hero-fade { position: absolute; inset: 0; background: linear-gradient(90deg, var(--bg-paper) 0%, rgba(246, 238, 227, 0) 22%); }
  .hero-chip {
    position: absolute;
    bottom: 26px;
    right: 28px;
    background: rgba(246, 238, 227, 0.9);
    backdrop-filter: blur(6px);
    border-radius: 14px;
    padding: 12px 18px;
    box-shadow: 0 8px 30px rgba(44, 35, 32, 0.18);
  }
  .hero-chip-title { font-family: var(--font-hand); font-size: 21px; color: var(--ink); line-height: 1.1; }
  .hero-chip-sub { font-size: 12px; color: var(--ink-soft); letter-spacing: 0.04em; text-transform: uppercase; margin-top: 3px; }

  /* theme strip */
  .theme-strip {
    background: var(--bg-paper-deep);
    border-top: 1px solid rgba(44, 35, 32, 0.08);
    border-bottom: 1px solid rgba(44, 35, 32, 0.08);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(10px, 2.4vw, 38px);
    flex-wrap: nowrap;
    overflow: hidden;
    white-space: nowrap;
    font-family: var(--font-serif);
    font-size: clamp(11px, 1.5vw, 18px);
    color: var(--ink-soft);
  }
  .theme-strip span { font-style: italic; }
  .theme-strip i { color: var(--accent); font-style: normal; }

  /* MEMOIR */
  .memoir {
    padding: clamp(64px, 9vw, 120px) var(--pad-x);
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(40px, 6vw, 88px);
    align-items: center;
  }
  .memoir-cover { position: relative; }
  .memoir-cover img { width: 100%; border-radius: 6px; box-shadow: 0 30px 70px rgba(44, 35, 32, 0.34); display: block; }
  .memoir-badge {
    position: absolute;
    top: -16px;
    left: -16px;
    background: var(--accent);
    color: var(--bg-paper);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 9px 16px;
    border-radius: 100px;
    box-shadow: 0 8px 24px rgba(164, 78, 44, 0.4);
  }
  .memoir-eyebrow { margin-bottom: 18px; }
  .memoir-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(38px, 4.6vw, 62px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .memoir-sub { font-family: var(--font-serif); font-style: italic; font-size: clamp(19px, 2vw, 24px); color: var(--ink-soft); margin-bottom: 28px; }
  .memoir-p { font-size: 17.5px; line-height: 1.72; color: var(--ink-soft-2); max-width: 56ch; margin-bottom: 20px; }
  .memoir-p em { font-family: var(--font-serif); font-style: italic; }
  .memoir-p--last { margin-bottom: 34px; }
  .memoir-ctas { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
  .memoir-aside { font-family: var(--font-hand); font-size: 22px; color: #7C7A5E; transform: rotate(-2deg); }

  /* POETRY (dark) */
  .poetry { background: var(--surface-dark); color: var(--on-dark); padding: clamp(64px, 9vw, 120px) var(--pad-x); }
  .poetry-head { text-align: center; max-width: 600px; margin: 0 auto 60px; }
  .poetry-head .eyebrow { margin-bottom: 16px; }
  .poetry-head h2 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(38px, 5vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
  }
  .poetry-em { font-style: italic; color: var(--accent-light); }
  .poetry-head p { font-size: 18px; line-height: 1.65; color: var(--on-dark-soft); }
  .poetry-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 3vw, 40px); max-width: 1180px; margin: 0 auto; }
  .book-card {
    display: flex;
    flex-direction: column;
    background: var(--surface-dark-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(246, 238, 227, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .book-card:hover { transform: translateY(-6px); box-shadow: 0 22px 44px rgba(0, 0, 0, 0.32); }
  .book-card--featured { box-shadow: 0 0 0 2px rgba(224, 162, 119, 0.35); }
  .book-card--featured:hover { box-shadow: 0 0 0 2px rgba(224, 162, 119, 0.55), 0 22px 44px rgba(0, 0, 0, 0.32); }
  .book-cover { aspect-ratio: 1 / 1; overflow: hidden; position: relative; }
  .book-cover img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .book-card:hover .book-cover img { transform: scale(1.04); }
  .book-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: var(--accent-light);
    color: var(--ink);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 100px;
  }
  .book-body { padding: 26px 24px 28px; display: flex; flex-direction: column; flex: 1; }
  .book-body h3 { font-family: var(--font-serif); font-style: italic; font-weight: 400; font-size: 25px; margin-bottom: 12px; }
  .book-body p { font-size: 15px; line-height: 1.6; color: var(--on-dark-soft); flex: 1; }
  .book-body p strong { color: var(--on-dark); }
  .book-body a {
    margin-top: 20px;
    color: var(--accent-light);
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    border-bottom: 1.5px solid rgba(224, 162, 119, 0.4);
    align-self: flex-start;
    padding-bottom: 2px;
  }

  /* CUSTOM POETRY */
  .custom { padding: clamp(64px, 9vw, 120px) var(--pad-x); }
  .custom-head { text-align: center; margin-bottom: 56px; }
  .custom-head .eyebrow { margin-bottom: 16px; }
  .custom-head h2 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(34px, 4.4vw, 58px); line-height: 1.02; letter-spacing: -0.02em; }
  .custom-em { font-style: italic; }
  .custom-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: clamp(36px, 5vw, 80px);
    align-items: center;
    max-width: 1180px;
    margin: 0 auto;
  }
  .custom-photo { position: relative; justify-self: center; max-width: 480px; }
  .custom-photo img { width: 100%; border-radius: 8px; box-shadow: 0 26px 60px rgba(44, 35, 32, 0.28); display: block; }
  .custom-tag {
    position: absolute;
    bottom: -16px;
    left: -20px;
    background: var(--ink);
    color: var(--bg-paper);
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 9px 16px;
    border-radius: 100px;
    box-shadow: 0 8px 22px rgba(44, 35, 32, 0.3);
  }
  .custom-title { font-family: var(--font-serif); font-weight: 400; font-size: clamp(27px, 3vw, 38px); line-height: 1.08; letter-spacing: -0.01em; margin-bottom: 20px; }
  .custom-p { font-size: 17.5px; line-height: 1.72; color: var(--ink-soft-2); max-width: 52ch; margin-bottom: 26px; }
  .custom-bullets { display: flex; flex-direction: column; gap: 12px; margin-bottom: 34px; }
  .custom-bullets div { display: flex; align-items: center; gap: 12px; font-size: 16px; color: var(--ink); }
  .custom-bullets i { color: var(--accent); font-size: 15px; font-style: normal; }
  .custom-ctas { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
  .gallery { max-width: 1180px; margin: clamp(48px, 6vw, 80px) auto 0; border-top: 1px solid rgba(44, 35, 32, 0.1); padding-top: clamp(40px, 5vw, 60px); }
  .gallery-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
  .gallery-head h3 { font-family: var(--font-serif); font-style: italic; font-weight: 400; font-size: clamp(22px, 2.4vw, 30px); }
  .gallery-head a { color: var(--accent); text-decoration: none; font-size: 15px; font-weight: 600; }
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(12px, 1.6vw, 20px); }
  .gallery-item {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(44, 35, 32, 0.16);
    border: 0;
    padding: 0;
    background: none;
    cursor: zoom-in;
    width: 100%;
  }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .gallery-item:hover img { transform: scale(1.05); }

