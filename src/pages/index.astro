</style>

<script>
  const track = document.querySelector<HTMLElement>('[data-carousel]');
  document.querySelectorAll<HTMLButtonElement>('[data-scroll]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!track) return;
      const dir = Number(btn.dataset.scroll);
      const step = Math.min(320, track.clientWidth * 0.9);
      track.scrollBy({ left: dir * step, behavior: 'smooth' });
    });
  });

  // Typewriter hero — retypes the headline on load, a nod to the
  // vintage-typewriter poetry. Static markup stays as the no-JS fallback.
  interface Seg { text?: string; br?: boolean; className?: string; }
  const title = document.getElementById('hero-title');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (title && !reduceMotion) {
    const segments: Seg[] = [
      { text: "I'm Michael —" },
      { br: true },
      { text: 'a writer', className: 'hero-em' },
      { text: ' at heart.' },
    ];
    // Lock in the rendered height first so retyping doesn't shift the layout.
    title.style.minHeight = `${title.offsetHeight}px`;
    title.textContent = '';
    const caret = document.createElement('span');
    caret.className = 'type-caret';
    title.appendChild(caret);

    let segIdx = 0;
    const typeSegment = () => {
      if (segIdx >= segments.length) {
        window.setTimeout(() => caret.classList.add('type-caret--done'), 1400);
        return;
      }
      const seg = segments[segIdx++];
      if (seg.br) {
        title.insertBefore(document.createElement('br'), caret);
        typeSegment();
        return;
      }
      const span = document.createElement('span');
      if (seg.className) span.className = seg.className;
      title.insertBefore(span, caret);
      const chars = seg.text ?? '';
      let charIdx = 0;
      const typeChar = () => {
        if (charIdx < chars.length) {
          span.textContent += chars[charIdx++];
          window.setTimeout(typeChar, 34 + Math.random() * 46);
        } else {
          typeSegment();
        }
      };
      typeChar();
    };
    window.setTimeout(typeSegment, 450);
  }
</script>
