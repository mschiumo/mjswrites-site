---
import type { Social } from '../lib/socials';

interface Props {
  social: Social;
  size?: number;
}

const { social, size = 18 } = Astro.props;
---
{social.path ? (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-hidden="true"
  >
    <path d={social.path} fill="currentColor"></path>
  </svg>
) : (
  <img src={social.img} alt="" width={size} height={size} style={`width:${size}px;height:${size}px;display:block`} />
)}
