---
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource-variable/instrument-sans';
import '@fontsource-variable/caveat';
import '@fontsource/courier-prime';
import '@fontsource/courier-prime/700.css';
import '../styles/global.css';
import { BOOKS, MEMOIR_ANNOUNCEMENT } from '../lib/socials';

interface Props {
  title: string;
  description?: string;
  /** Which nav item to highlight. */
  active?: 'home' | 'shop' | 'blog' | 'contact';
  /** Override the nav CTA (Contact page uses "Say hello" → #form). */
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  description = 'Michael J. Schiuma — author of (In)Sane, poet, and mental-health advocate.',
  active,
  ctaLabel = 'Get in touch',
  ctaHref = '/contact/',
} = Astro.props;

const NAV = [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'shop', label: 'Shop', href: '/shop/' },
  { id: 'blog', label: 'Blog', href: '/blog/' },
  { id: 'contact', label: 'Contact', href: '/contact/' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <slot name="head" />
  </head>
  <body>
    <div class="announcement">
      <a href={MEMOIR_ANNOUNCEMENT} target="_blank" rel="noopener">
        <span class="star">✦</span>&nbsp;&nbsp;<em>(In)Sane</em> — my memoir on bipolar, madness &amp; recovery is out now
        <span class="read-it">Read it →</span>
      </a>
    </div>

    <nav>
      <a href="/" class="wordmark">
        <span class="wm-mjs">MJS</span><span class="wm-writes">Writes</span>
      </a>
      <div class="nav-links">
        {NAV.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: active === item.id }]}>{item.label}</a>
        ))}
        <a href={ctaHref} class="nav-cta">{ctaLabel}</a>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="footer-top">
        <div>
          <div class="footer-wordmark"><span class="wm-mjs">MJS</span><span class="wm-writes-dark">Writes</span></div>
          <p class="footer-tagline">Author, poet &amp; mental-health advocate — writing on bipolar and recovery, plus travel, technology, politics, and poetry.</p>
        </div>
        <div class="footer-cols">
          <div class="footer-col">
            <div class="footer-label">Explore</div>
            {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
          <div class="footer-col">
            <div class="footer-label">Books</div>
            {BOOKS.map((b) => <a href={b.url} target="_blank" rel="noopener">{b.name}</a>)}
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 MJS Writes — All rights reserved.</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .announcement {
    background: var(--ink);
    color: var(--on-dark);
    text-align: center;
    padding: 10px 20px;
    font-size: 13.5px;
    letter-spacing: 0.02em;
    font-weight: 500;
  }
  .announcement a { color: var(--on-dark); text-decoration: none; }
  .announcement .star { color: var(--accent-light); }
  .announcement em { font-family: var(--font-serif); font-style: italic; font-size: 15px; }
  .announcement .read-it { text-decoration: underline; text-underline-offset: 3px; margin-left: 6px; }

  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246, 238, 227, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(44, 35, 32, 0.09);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 40px;
  }
  .wordmark { text-decoration: none; display: flex; align-items: baseline; gap: 9px; }
  .wm-mjs {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: 0.14em;
    color: var(--ink);
  }
  .wm-writes {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 24px;
    color: var(--accent);
  }
  .nav-links { display: flex; align-items: center; gap: 34px; }
  .nav-link { color: var(--ink); text-decoration: none; font-size: 15px; font-weight: 500; }
  .nav-link:hover { color: var(--accent); }
  .nav-link.active { color: var(--accent); font-weight: 600; }
  .nav-cta {
    background: var(--accent);
    color: var(--bg-paper);
    text-decoration: none;
    font-size: 14.5px;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: 100px;
    box-shadow: 0 2px 10px rgba(164, 78, 44, 0.28);
    transition: background 0.25s ease;
  }
  .nav-cta:hover { background: var(--accent-deep); }

  footer {
    background: var(--ink-footer);
    color: var(--on-dark-soft);
    padding: clamp(48px, 6vw, 72px) var(--pad-x) 40px;
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
    border-bottom: 1px solid rgba(246, 238, 227, 0.1);
    padding-bottom: 36px;
    margin-bottom: 26px;
  }
  .footer-wordmark { font-family: var(--font-serif); font-size: 26px; color: var(--on-dark); margin-bottom: 8px; }
  .footer-wordmark .wm-mjs { font-size: inherit; color: inherit; }
  .wm-writes-dark { font-style: italic; color: var(--accent-light); margin-left: 9px; }
  .footer-tagline { font-size: 15px; line-height: 1.6; max-width: 42ch; }
  .footer-cols { display: flex; gap: 56px; flex-wrap: wrap; }
  .footer-col { display: flex; flex-direction: column; gap: 11px; }
  .footer-label {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-footer);
    margin-bottom: 4px;
  }
  .footer-col a { color: var(--on-dark-soft); text-decoration: none; font-size: 15px; }
  .footer-col a:hover { color: var(--on-dark); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13.5px;
    color: var(--muted-footer);
  }

  @media (max-width: 760px) {
    nav { padding: 14px 20px; flex-wrap: wrap; gap: 10px; }
    .nav-links { gap: 18px; flex-wrap: wrap; }
  }
</style>
